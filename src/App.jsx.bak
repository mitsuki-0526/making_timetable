import React, { useState } from 'react';
import TimetableGrid from './components/TimetableGrid';
import ValidationPanel from './components/ValidationPanel';
import SettingsModal from './components/SettingsModal';
import FileActions from './components/FileActions';

// 一時的に無効化
// import TeacherScheduleGrid from './components/TeacherScheduleGrid';
// import AIAssistPanel from './components/AIAssistPanel';

function App() {
  const [isSettingsOpen, setIsSettingsOpen] = useState(false);
  const [isAIOpen, setIsAIOpen] = useState(false);
  const [activeView, setActiveView] = useState('class'); // 'class' | 'teacher'

  const tabStyle = (view) => ({
    padding: '0.5rem 1.4rem',
    border: 'none',
    borderRadius: '6px 6px 0 0',
    cursor: 'pointer',
    fontSize: '0.9rem',
    fontWeight: activeView === view ? 700 : 400,
    backgroundColor: activeView === view ? '#fff' : 'transparent',
    color: activeView === view ? '#1E40AF' : '#64748B',
    borderBottom: activeView === view ? '2px solid #1E40AF' : '2px solid transparent',
    transition: 'all 0.15s',
  });

  return (
    <div className="layout">
      <header className="header" style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
        <h1>時間割作成ツール</h1>
        <div style={{ display: 'flex', gap: '1rem', alignItems: 'center' }}>
          <FileActions />
          <button
            onClick={() => setIsAIOpen(true)}
            style={{
              padding: '0.5rem 1rem', border: 'none', borderRadius: '6px', cursor: 'pointer',
              background: 'linear-gradient(135deg, #6366F1, #8B5CF6)',
              color: '#fff', fontWeight: 600, fontSize: '0.9rem',
            }}
          >
            🤖 AI支援
          </button>
          <button className="btn-primary" onClick={() => setIsSettingsOpen(true)}>⚙️ マスタ設定</button>
        </div>
      </header>

      {/* ビュー切替タブ */}
      <div style={{
        display: 'flex',
        gap: '0.25rem',
        padding: '0.75rem 1.5rem 0',
        backgroundColor: '#F8FAFC',
        borderBottom: '1px solid #E2E8F0',
      }}>
        <button style={tabStyle('class')} onClick={() => setActiveView('class')}>
          📋 クラス別時間割
        </button>
        <button style={tabStyle('teacher')} onClick={() => setActiveView('teacher')}>
          👤 先生別時間割
        </button>
      </div>

      <main className="main-content">
        {activeView === 'class' && (
          <>
            <TimetableGrid />
            <ValidationPanel />
          </>
        )}
        {activeView === 'teacher' && (
          <TeacherScheduleGrid />
        )}
      </main>

      {isSettingsOpen && <SettingsModal onClose={() => setIsSettingsOpen(false)} />}
      {isAIOpen && <AIAssistPanel onClose={() => setIsAIOpen(false)} />}
    </div>
  );
}

export default App;
