{
  "name": "timetable-creator-desktop",
  "version": "0.1.0",
  "description": "時間割作成ツール (デスクトップ版)",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,PYTHON,ELECTRON \"npm run dev:vite\" \"npm run dev:python\" \"wait-on tcp:5173 tcp:8000 && electron .\"",
    "dev:vite": "vite",
    "dev:python": "uv run --project python python/server.py",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^0.320.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.2",
    "electron": "^29.4.6",
    "electron-builder": "^25.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.21",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.timetable.creator.desktop",
    "productName": "時間割作成ツール",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "python/",
        "to": "python/"
      }
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
