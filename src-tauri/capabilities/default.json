{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "時間割ツールの標準権限",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$DOCUMENT/**" }]
    }
  ]
}
