{
  "name": "timetable-creator",
  "version": "1.0.0",
  "description": "時間割作成ツール",
  "author": "School Tools Team",
  "homepage": "https://mitsuki-0526.github.io/making_timetable",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:electron": "set ELECTRON=true&& vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "electron:pack": "npm run build:electron && electron-builder --dir",
    "electron:dist": "npm run build:electron && electron-builder",
    "build:web": "vite build",
    "predeploy": "npm run build:web",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "lucide-react": "^0.320.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^29.0.0",
    "electron-builder": "^25.1.8",
    "gh-pages": "^6.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.1.0",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.timetable.creator",
    "productName": "時間割作成ツール",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
