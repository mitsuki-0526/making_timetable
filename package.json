{
  "name": "timetable-creator",
  "version": "1.0.0",
  "description": "時間割作成ツール",
  "author": "School Tools Team",
  "homepage": "https://mitsuki-0526.github.io/making_timetable",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:electron": "set ELECTRON=true&& vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "electron:pack": "npm run build:electron && electron-builder --dir",
    "electron:dist": "npm run build:electron && electron-builder",
    "build:web": "vite build",
    "predeploy": "npm run build:web",
    "deploy": "gh-pages -d dist",
    "format": "biome format",
    "lint": "biome check"
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.10",
    "lucide-react": "^1.7.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "gh-pages": "^6.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^8.0.7",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.timetable.creator",
    "productName": "時間割作成ツール",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
